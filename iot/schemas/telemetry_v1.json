{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://water.city/schemas/telemetry_v1.json",
  "title": "Water IoT Telemetry v1",
  "type": "object",
  "required": ["device_id", "device_type", "timestamp", "metrics"],
  "properties": {
    "device_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "device_type": {
      "type": "string",
      "enum": ["flow_meter", "reservoir_level", "pressure_sensor", "groundwater"]
    },
    "city_id": { "type": "string", "default": "delhi-ncr" },
    "zone_code": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "metrics": { "type": "object", "minProperties": 1 },
    "quality": { "type": "string", "enum": ["good", "uncertain", "bad"], "default": "good" },
    "edge_gateway_id": { "type": "string" },
    "battery_percent": { "type": "number", "minimum": 0, "maximum": 100 }
  },
  "allOf": [
    {
      "if": { "properties": { "device_type": { "const": "flow_meter" } } },
      "then": {
        "properties": {
          "metrics": {
            "required": ["flow_rate_lpm"],
            "properties": {
              "flow_rate_lpm": { "type": "number", "minimum": 0 },
              "cumulative_volume_liters": { "type": "number", "minimum": 0 },
              "velocity_mps": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "device_type": { "const": "reservoir_level" } } },
      "then": {
        "properties": {
          "metrics": {
            "required": ["level_percent"],
            "properties": {
              "level_m": { "type": "number" },
              "level_percent": { "type": "number", "minimum": 0, "maximum": 100 },
              "volume_m3": { "type": "number", "minimum": 0 },
              "inflow_lpm": { "type": "number", "minimum": 0 },
              "outflow_lpm": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "device_type": { "const": "pressure_sensor" } } },
      "then": {
        "properties": {
          "metrics": {
            "required": ["pressure_bar"],
            "properties": {
              "pressure_bar": { "type": "number", "minimum": 0 },
              "pressure_kpa": { "type": "number", "minimum": 0 },
              "differential_bar": { "type": "number" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "device_type": { "const": "groundwater" } } },
      "then": {
        "properties": {
          "metrics": {
            "required": ["water_table_m"],
            "properties": {
              "water_table_m": { "type": "number" },
              "drawdown_m": { "type": "number", "minimum": 0 },
              "conductivity_us_cm": { "type": "number", "minimum": 0 },
              "temperature_c": { "type": "number" }
            }
          }
        }
      }
    }
  ]
}
